# ── Backend environment variables ──────────────────────────────────────────────
# Copy to .env for local dev.

DATABASE_URL="mysql://root:YOUR_MYSQL_ROOT_PASSWORD@127.0.0.1:3306/newsportal"

PORT=5000
NODE_ENV=development

JWT_SECRET="replace_with_at_least_32_random_chars"
JWT_EXPIRES_IN="7d"

# CORS — allowed browser origins (comma-separated, no trailing slash)
# If unset, FRONTEND_URL below is used for CORS as well.
CORS_ORIGINS=

# Site URL (cookies / defaults); can be comma-separated; first entry used where a single URL is needed
FRONTEND_URL="http://localhost:3000"
