# ── Backend environment variables ──────────────────────────────────────────────
# Copy to .env for local dev.

DATABASE_URL="mysql://root:YOUR_MYSQL_ROOT_PASSWORD@127.0.0.1:3306/newsportal"

PORT=5000
NODE_ENV=development

JWT_SECRET="replace_with_at_least_32_random_chars"
JWT_EXPIRES_IN="7d"

# CORS — comma-separated list of allowed frontend origins
FRONTEND_URL="http://localhost:3000"

# Redis (optional — only needed if BullMQ queue worker is enabled)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
