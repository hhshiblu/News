
DB_ROOT_PASSWORD=change_me_strong_password
DB_NAME=newsportal

# ── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_at_least_32_random_chars
JWT_EXPIRES_IN=7d

# ── Public URLs (IP:port — no domain) ───────────────────────────────────────────
# Same host IP, different ports for site vs API, e.g.:
#   FRONTEND_URL=http://203.0.113.10:3000
#   NEXT_PUBLIC_API_URL=http://203.0.113.10:5000/api/v1
#   NEXT_PUBLIC_FRONTEND_URL=http://203.0.113.10:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# ── CORS (backend) — comma-separated origins, no trailing slashes ───────────────
# If empty, FRONTEND_URL is used (also supports comma-separated there).
# Example: CORS_ORIGINS=http://203.0.113.10:3000,http://127.0.0.1:3000
CORS_ORIGINS=

BACKEND_INTERNAL_URL=http://backend:5000
# Must match how the browser reaches the API (same host as the site, API port). Used at Next build for rewrites + client fetch.
# Example from another PC: NEXT_PUBLIC_API_URL=http://192.168.1.5:5000/api/v1

# ── Admin cookie (http://IP:3000 + API on :5000) ───────────────────────────────
# NODE_ENV=production on the server is correct (optimizations). Do NOT need development for cookies.
# SSL: optional on IP. Without HTTPS, do not set COOKIE_SECURE=true (or leave unset — we auto-disable
# Secure when FRONTEND_URL is http://). Cookie name stays "accessToken"; IP does not remove headers.
# Force flags: COOKIE_SECURE=true only behind HTTPS; COOKIE_SECURE=false forces plain HTTP cookies.
COOKIE_SECURE=

