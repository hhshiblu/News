# ─── Central environment variables ─────────────────────────────────────────────
# Copy this file to .env and fill in the real values.
# docker-compose.yml reads from .env in the repo root.

# ── Database ────────────────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=change_me_strong_password
DB_NAME=newsportal

# ── JWT ─────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_at_least_32_random_chars
JWT_EXPIRES_IN=7d

# ── URLs ─────────────────────────────────────────────────────────────────────────
# Public URL of the frontend (used for CORS in the backend)
FRONTEND_URL=http://localhost:3000

# Public URL of the API (used by Next.js client-side code)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# Internal URL for Next.js SSR → backend calls inside Docker network
# (do not change unless you rename the backend service in docker-compose)
BACKEND_INTERNAL_URL=http://backend:5000
